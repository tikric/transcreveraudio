{
  "entities": {
    "Transcript": {
      "title": "Transcript",
      "description": "An audio transcription processed by Gemini AI",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier of the transcript"
        },
        "title": {
          "type": "string",
          "description": "Title of the transcript"
        },
        "fileName": {
          "type": "string",
          "description": "Name of the uploaded audio"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of creation"
        },
        "duration": {
          "type": "string",
          "description": "Formatted duration representation"
        },
        "durationSeconds": {
          "type": "number",
          "description": "Total duration in seconds"
        },
        "language": {
          "type": "string",
          "description": "Transcription language code"
        },
        "accuracyMode": {
          "type": "string",
          "enum": ["accuracy", "speed", "default"],
          "description": "AI transcription mode"
        },
        "status": {
          "type": "string",
          "enum": ["completed", "processing", "failed"],
          "description": "Current status of transcription"
        },
        "summary": {
          "type": "string",
          "description": "Brief summary generated by Gemini AI"
        },
        "ownerId": {
          "type": "string",
          "description": "UID of the owner of this transcript"
        },
        "isPublic": {
          "type": "boolean",
          "description": "Indicates whether this transcript is shared publicly"
        }
      },
      "required": [
        "id",
        "title",
        "fileName",
        "createdAt",
        "duration",
        "durationSeconds",
        "language",
        "accuracyMode",
        "status",
        "ownerId",
        "isPublic"
      ]
    }
  },
  "firestore": {
    "/transcripts/{transcriptId}": {
      "schema": "Transcript",
      "description": "Collection of all user transcripts"
    }
  }
}
